# Build outputs (proxy DLL is deployed straight into the game root, not committed)
proxy_d3d9/obj/
proxy_d3d9/Debug/
proxy_d3d9/Release/
*.obj
*.pdb
*.ilk
*.log
*.exp
*.lib
d3d9.dll

# Never commit a copy of any Microsoft system DLL, even accidentally staged for testing.
d3d9_orig.dll

# User-generated config (task #14) -- written fresh with defaults by mod_config.cpp
# on first run at the game root, never meant to be committed (personal tuning values).
mw3ncp_config.ini

# User's own scratch live-test notes (jotted during playtests, read back in during
# dev sessions) -- personal working notes, not a project doc, never meant to be committed.
notes.txt

# Build outputs for dev-only test tools (not shipped, not part of the mod)
tools/*/bin/
tools/*/obj/
vcontroller_sim.exe
memdiff.exe
regbreak.exe

# memdiff full-process memory snapshots (~400MB each) -- diagnostic scratch data, never
# meant to be committed
tools/memdiff/*.snap

# Third-party reference material (cloned locally for research only -- learn from and
# independently re-verify, never blindly reuse; see re_notes for how any lead from here
# gets treated). Not ours to redistribute as part of this repo.
references/

# Extracted MW3 game assets (from OpenAssetTools' Unlinker, run against our own retail
# .ff fastfiles for RE purposes -- see re_notes/iw5sp.md) are Activision's copyrighted
# game data, never ours to redistribute. Dumped outside this repo by default (D:\Tools),
# but ignored here too as a defensive safety net in case any dump output ever lands
# inside the repo by accident.
zone_dump/
ff_dump/
*.gdt
